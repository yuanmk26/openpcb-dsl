{
  "name": "openpcb-dsl",
  "version": "0.1.0",
  "description": "Compiler core for OpenPCB DSL to AST, IR, and preliminary emitter outputs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openpcb-dsl": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm --dir ../openpcb-schematic-core build && pnpm --dir ../openpcb-schematic-symbols build && pnpm --dir ../openpcb-schematic-tscircuit build && pnpm --dir ../openpcb-schematic-svg build && tsup src/index.ts src/cli/index.ts --format esm --dts",
    "test": "vitest run",
    "dev": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openpcb",
    "pcb",
    "dsl",
    "compiler",
    "electronics"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.1.1",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@tscircuit/alphabet": "^0.0.25",
    "@tscircuit/circuit-json-util": "^0.0.94",
    "circuit-json": "^0.0.426",
    "circuit-json-to-connectivity-map": "^0.0.23",
    "circuit-to-svg": "^0.0.347",
    "openpcb-schematic-core": "file:../openpcb-schematic-core",
    "openpcb-schematic-svg": "file:../openpcb-schematic-svg",
    "openpcb-schematic-symbols": "file:../openpcb-schematic-symbols",
    "openpcb-schematic-tscircuit": "file:../openpcb-schematic-tscircuit",
    "schematic-symbols": "^0.0.224"
  }
}
